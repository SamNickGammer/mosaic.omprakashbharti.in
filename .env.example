# --- Database (Neon) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# --- App base URL ---
# Canonical public URL of the app, used to build the callback URLs baked into
# agent bootstrap prompts. Leave BLANK in dev — it auto-detects the real host
# and port from the request (so localhost:3005 shows localhost:3005). Set it in
# production to your deployed domain, e.g. https://mosaic.example.com
APP_URL=

# --- NextAuth ---
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Encryption (AES-256-GCM for API keys) ---
# 32-byte hex string: openssl rand -hex 32
ENCRYPTION_KEY=

# Vercel cron auth (session health check)
CRON_SECRET=
# Vercel Blob (task attachments — Phase 2+ upload)
BLOB_READ_WRITE_TOKEN=
